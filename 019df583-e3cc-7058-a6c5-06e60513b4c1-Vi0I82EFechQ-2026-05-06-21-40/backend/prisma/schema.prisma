generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Registration {
  id               String   @id @default(cuid())
  parentName       String
  childName        String
  childAge         Int
  sport            String
  email            String
  phone            String
  emergencyContact String
  medicalNotes     String   @default("")
  tshirtSize       String
  consentSigned    Boolean  @default(true)
  createdAt        DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
